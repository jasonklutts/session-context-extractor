{
  "name": "session-context-extractor",
  "version": "0.1.0",
  "description": "Auto-capture decision reasoning, error history, preferences, and relationships from agent sessions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "extract": "ts-node src/cli.ts extract",
    "query": "ts-node src/cli.ts query",
    "demo": "ts-node src/scripts/demo.ts",
    "setup": "ts-node src/scripts/setup.ts"
  },
  "keywords": [
    "memory",
    "agent",
    "context",
    "decision-tracking",
    "error-history",
    "preferences"
  ],
  "author": "Jason Klutts",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "lunr": "^2.3.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/lunr": "^2.3.5",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
